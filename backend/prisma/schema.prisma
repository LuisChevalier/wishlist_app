// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Representa a un usuario registrado en el sistema.
model User {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String
  items        WishlistItem[]
  createdAt    DateTime       @default(now())
}

// Representa un ítem individual de la lista de deseos.
// Cada ítem pertenece obligatoriamente a un usuario (Relación N:1).
model WishlistItem {
  id               String   @id @default(cuid())
  name             String
  price            Float    @default(0.0)
  priority         Int      @default(1) // 0: baja, 1: media, 2: alta
  isCompleted      Boolean  @default(false)
  imageUri         String?  // Opcional
  purchaseLocation String?  // Agregado desde Flutter
  expectedDate     DateTime? // Agregado desde Flutter
  notes            String?  // Agregado desde Flutter
  createdAt        DateTime @default(now())

  // Relación con el usuario dueño
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
}
